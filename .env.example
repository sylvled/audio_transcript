# ──────────────────────────────────────────────────────────────
# Audio Transcript — Configuration
# Copiez ce fichier en .env et renseignez vos clés
# ──────────────────────────────────────────────────────────────

# ── Claude (Anthropic) ─────────────────────────────────────────
# Clé API pour le post-traitement et la correction de transcription
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-VOTRE_CLE_ICI

# ── HuggingFace ────────────────────────────────────────────────
# Token pour télécharger le modèle de diarisation pyannote
# 1. Créez un token READ sur https://huggingface.co/settings/tokens
# 2. Acceptez les CGU sur https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_VOTRE_TOKEN_ICI

# ── Options Whisper ────────────────────────────────────────────
# Modèle par défaut (peut être surchargé avec --model en CLI)
# Valeurs : tiny | base | small | medium | large-v2 | large-v3 | large-v3-turbo
WHISPER_MODEL=large-v3