# ──────────────────────────────────────────────────────────────
# Audio Transcript - Configuration
# Copiez ce fichier en .env et renseignez vos cles
# ──────────────────────────────────────────────────────────────

# ── Claude (Anthropic) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-VOTRE_CLE_ICI

# ── HuggingFace ────────────────────────────────────────────────
# Token pour telecharger le modele de diarisation pyannote
# 1. Creez un token READ sur https://huggingface.co/settings/tokens
# 2. Acceptez les CGU sur :
#    https://huggingface.co/pyannote/speaker-diarization-3.1
#    https://huggingface.co/pyannote/speaker-diarization-community-1
#    https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=hf_VOTRE_TOKEN_ICI

# ── Options Whisper ────────────────────────────────────────────
# Modele par defaut (peut etre surcharge avec --model en CLI)
# Valeurs : tiny | base | small | medium | large-v2 | large-v3 | large-v3-turbo
WHISPER_MODEL=large-v3

# ── LLM Backend ────────────────────────────────────────────────
# auto   = Groq si dispo, sinon Ollama, sinon Claude
# groq   = Groq API (gratuit) -- recommande
# ollama = LLM local (necessite Ollama installe)
# claude = Anthropic Claude (payant)
# none   = pas de traitement LLM
LLM_BACKEND=auto

# ── Groq (gratuit) ─────────────────────────────────────────────
# Inscription : https://console.groq.com -> API Keys
GROQ_API_KEY=gsk_VOTRE_CLE_ICI
GROQ_MODEL=llama-3.1-8b-instant
# Tokens max par chunk (free tier : limite 6k tokens/requete)
# Laisser a 1500 pour eviter les erreurs 413 sur texte francais
GROQ_CHUNK_TOKENS=1500

# ── Ollama (local, gratuit) ────────────────────────────────────
# Installation : https://ollama.ai  puis : ollama pull mistral
OLLAMA_MODEL=mistral

# ── Claude (Anthropic, payant) ────────────────────────────────
# claude-sonnet-4-5 = rapide, tres bon
# claude-opus-4-6   = plus lent, meilleure qualite
CLAUDE_MODEL=claude-sonnet-4-5

# ── Divers ──────────────────────────────────────────────────────
HF_HUB_DISABLE_SYMLINKS_WARNING=1
